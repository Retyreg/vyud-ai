# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env

# Telegram
TELEGRAM_BOT_TOKEN=

# OpenAI
OPENAI_API_KEY=

# LlamaCloud (опционально, для PDF с таблицами)
LLAMA_CLOUD_API_KEY=

# Supabase — используйте service_role key (не anon!)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=

# API ключи для Mini App (список через запятую)
API_KEYS=your-secret-key-here

# Секрет для webhook Telegram (любая случайная строка)
WEBHOOK_SECRET=your-webhook-secret-here

# Vyud AI Platform - Configuration Secrets Example
# Скопируйте этот файл в secrets.toml и заполните реальными значениями

# OpenAI API Key для Whisper и GPT-4
# Получить: https://platform.openai.com/api-keys
OPENAI_API_KEY = "sk-proj-your-openai-key-here"

# Llama Cloud API Key для парсинга документов
# Получить: https://cloud.llamaindex.ai/api-key
LLAMA_CLOUD_API_KEY = "llx_your-llama-cloud-key-here"

# Supabase Configuration
# Получить: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL = "https://your-project-id.supabase.co"
SUPABASE_KEY = "your-supabase-anon-key-here"

# Admin credentials
ADMIN_EMAIL = "admin@example.com"
ADMIN_PASSWORD = "your-secure-password"

# Telegram Bot Token (опционально)
# Получить: https://t.me/BotFather
TELEGRAM_BOT_TOKEN = "your-telegram-bot-token-here"

# API Keys для REST API (можно несколько через запятую)
API_KEYS = "your-api-key-1,your-api-key-2"
